rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper : vérifie que l'utilisateur est dans la collection admins
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Guild members — lecture publique, écriture Cloud Functions uniquement (Admin SDK)
    match /guild-members/{memberId} {
      allow read: if true;
      allow write: if false;
    }

    // Snapshots — lecture publique, écriture Cloud Functions uniquement (Admin SDK)
    match /guild-roster-snapshots/{snapshotId} {
      allow read: if true;
      allow write: if false;
    }

    // Roster sondage — lecture publique, écriture via submitRosterEntry Cloud Function (Admin SDK)
    // Les clients Discord ne passent pas par Firebase Auth → write: false est sûr
    match /roster/{responseId} {
      allow read: if true;
      allow write: if false;
    }

    // Admins — self-read uniquement (un utilisateur ne peut lire que son propre doc)
    // Empêche l'énumération de tous les emails admin
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // Progression raid — lecture publique, écriture admin uniquement
    match /progression/{raidId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Actualités — lecture publique, écriture admin uniquement
    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Galerie membres — lecture publique, création ouverte (gate Discord côté client), suppression admin
    match /gallery/{docId} {
      allow read: if true;
      allow create: if true;
      allow delete: if isAdmin();
      allow update: if false;
    }

    // Attendance mapping Discord↔WoW — lecture publique, écriture admin uniquement
    match /attendance-mapping/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // WCL cache — lecture publique, écriture Cloud Functions uniquement (Admin SDK)
    match /wcl-reports/{reportCode} {
      allow read: if true;
      allow write: if false;
    }

    // Default : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
